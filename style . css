
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:Arial,sans-serif;
    background:#f4f7fc;
    color:#333;
}

nav{
    background:#0d6efd;
    padding:15px;
    text-align:center;
}

nav a{
    color:white;
    text-decoration:none;
    margin:15px;
    font-size:18px;
    font-weight:bold;
}

nav a:hover{
    color:yellow;
}

section{
    text-align:center;
    padding:50px 20px;
}

h1{
    font-size:40px;
    color:#0d6efd;
}

h2{
    color:#0d6efd;
    margin:20px 0;
    text-align:center;
}

p{
    width:80%;
    margin:15px auto;
    line-height:1.8;
    text-align:center;
}

ul{
    width:60%;
    margin:20px auto;
}

li{
    margin:10px 0;
    font-size:18px;
}

hr{
    width:80%;
    margin:30px auto;
}

a{
    color:#0d6efd;
}